{#
/**
 * @file
 * Theme override for links--dropbutton.html.twig
 */
#}
{% if links -%}
  {# Convert Dropbutton to a simple list #}
  {% if 'dropbutton' in attributes.class %}
    {% set attributes = attributes.removeClass('dropbutton').addClass('icon-actions-list') %}
  {% endif %}

  <ul{{ attributes }}>
    {%- for item in links -%}
      {# Generate a unique class based on the link text (e.g., 'action-edit') #}
      {% set action_class = 'action-' ~ item.text|lower|replace({' ': '-'}) %}
      
      <li{{ item.attributes.addClass(action_class) }}>
        {%- if item.link -%}
          {{ item.link }}
        {%- elseif item.text_attributes -%}
          <span{{ item.text_attributes }}>{{ item.text }}</span>
        {%- else -%}
          {{ item.text }}
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
{%- endif %}